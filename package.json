{
    "name": "yoosk-launcher",
    "private": true,
    "version": "1.2.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsc && vite build",
        "preview": "vite preview",
        "tauri": "tauri",
        "openapi:download": "curl -Lo ./src/lib/api/openapi.json http://localhost:3000/openapi.json",
        "openapi:generate": "openapi typegen ./src/lib/api/openapi.json > ./src/openapi.d.ts",
        "openapi:update": "pnpm run openapi:download && pnpm run openapi:generate",
        "format": "prettier --write \"src/**/*.{ts,tsx}\""
    },
    "dependencies": {
        "@tailwindcss/vite": "^4.3.0",
        "@tanstack/react-query": "^5.101.0",
        "@tauri-apps/api": "^2.11.0",
        "@tauri-apps/plugin-dialog": "^2.6.0",
        "@tauri-apps/plugin-opener": "^2.5.4",
        "@tauri-apps/plugin-process": "^2.3.1",
        "@tauri-apps/plugin-updater": "^2.10.1",
        "axios": "^1.17.0",
        "base32-encode": "^2.0.0",
        "i18next": "^25.10.10",
        "i18next-http-backend": "^3.0.6",
        "lucide-react": "^0.563.0",
        "openapi-client-axios": "^7.9.0",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "react-hook-form": "^7.77.0",
        "react-i18next": "^16.6.6",
        "react-qr-code": "^2.0.21",
        "react-router": "^7.17.0",
        "react-skinview3d": "^7.0.0",
        "skinview3d": "^3.4.2",
        "styled-components": "^6.4.2",
        "tailwindcss": "^4.3.0",
        "totp-generator": "^2.0.1",
        "zustand": "^5.0.14"
    },
    "devDependencies": {
        "@tauri-apps/cli": "^2.11.2",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^4.7.0",
        "javascript-obfuscator": "^4.2.2",
        "openapicmd": "^2.9.2",
        "prettier": "^3.8.3",
        "vite": "^7.3.1",
        "vite-plugin-javascript-obfuscator": "^3.1.0"
    }
}
