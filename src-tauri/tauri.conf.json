{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Yoosk Launcher",
    "version": "1.2.0",
    "identifier": "com.yoosk.launcher",
    "build": {
        "beforeDevCommand": "npm run dev",
        "devUrl": "http://127.0.0.1:1420",
        "beforeBuildCommand": "npm run build",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [
            {
                "title": "Yoosk Launcher",
                "width": 1080,
                "height": 600,
                "minWidth": 1080,
                "minHeight": 600,
                "decorations": false
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "resources": [
            "resources/*"
        ],
        "createUpdaterArtifacts": true
    },
    "plugins": {
        "updater": {
            "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg1MzQ2NDRDNUI3QUI5MzQKUldRMHVYcGJUR1EwaGNvZStoYW9aT0Z1SjIvYnpXcXorSVNQclhlaU4zVnJzbWdUMFN0QXgraHAK",
            "endpoints": [
                "https://github.com/YooskDev/valoria-launcher-public/releases/latest/download/latest.json"
            ]
        }
    }
}